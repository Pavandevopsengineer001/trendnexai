# ============================================================================
# TrendNexAI Production Configuration
# Copy this file to .env and update values for your deployment
# ============================================================================

# Environment
ENV=production
NODE_ENV=production
LOG_LEVEL=INFO

# ============================================================================
# Database Configuration
# ============================================================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_secure_mongodb_password_here
MONGO_PORT=27017

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379

# ============================================================================
# API & Service Credentials
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
NEWS_API_KEY=your_newsapi_key_here
SECRET_KEY=your_super_secret_jwt_key_change_in_production

# ============================================================================
# Admin Credentials (Change immediately after first login!)
# ============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_secure_password

# ============================================================================
# Frontend Configuration
# ============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# CORS & Security
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# Port Configuration
# ============================================================================
BACKEND_PORT=8001
FRONTEND_PORT=3000

# ============================================================================
# Optional: Analytics & Monitoring
# ============================================================================
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXXXXXX-X
SENTRY_DSN=
DATADOG_API_KEY=

# ============================================================================
# Optional: Ad Networks & Monetization
# ============================================================================
GOOGLE_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
GOOGLE_ADSENSE_SLOTS=slot-id-1,slot-id-2,slot-id-3

# ============================================================================
# Optional: Email Configuration
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================================================
# Optional: AWS/Cloud Storage
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_PREMIUM_FEATURES=false
ENABLE_USER_REGISTRATION=true
ENABLE_COMMENTS=false

# ============================================================================
# News Fetch Configuration
# ============================================================================
NEWS_FETCH_INTERVAL_MINUTES=30
ARTICLES_PER_CATEGORY=10
GENERATE_AI_SUMMARY=true
GENERATE_SEO_METADATA=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ========== DEPLOYMENT ==========
# Environment
ENV=development  # development, staging, production

# Logging
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Deployment
PORT=8000
WORKERS=4
