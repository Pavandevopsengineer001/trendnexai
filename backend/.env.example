# FastAPI Backend Environment Variables

# ========== SERVER ==========
ENV=development
DEBUG=true
LOG_LEVEL=INFO
PORT=8000
WORKERS=4

# ========== DATABASE ==========
MONGODB_URI=mongodb://admin:password@localhost:27017/trendnexai?authSource=admin
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# ========== AUTHENTICATION ==========
SECRET_KEY=your-super-secret-key-change-in-production-32-chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secure_password_change_me

# ========== REDIS / CACHE ==========
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# ========== OPENAI ==========
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=2000

# ========== NEWS SOURCES ==========
NEWS_API_KEY=your_newsapi_key_here
NEWS_FETCH_INTERVAL_MINUTES=30
NEWS_LIMIT_PER_CATEGORY=10

# ========== CELERY ==========
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ========== EMAIL ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@trendnexai.com

# ========== CORS & SECURITY ==========
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
ALLOW_CREDENTIALS=true

# ========== SENTRY (Error Tracking) ==========
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ========== AWS (Optional) ==========
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=
